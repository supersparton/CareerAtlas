GROQ_API_KEY=your_groq_api_key_here
# To load-balance multiple API keys (e.g. to bypass rate limits), list them comma-separated:
GROQ_API_KEYS=gsk_key1,gsk_key2,gsk_key3
GEMINI_API_KEYS=gemini_key1,gemini_key2
TINYFISH_API_KEY=your_tinyfish_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Ollama Local LLM Configuration (For rate limit bypass / local testing)
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Database configuration (Compatible with Supabase / PostgreSQL)
# Supply a single connection string:
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
# Or supply individual configuration keys:
# DB_HOST=db.xxx.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=postgres
# DB_SSL=true

# Qdrant Vector DB Configuration (Qdrant Cloud cluster)
QDRANT_URL=https://your-qdrant-cluster-url.qdrant.tech
QDRANT_API_KEY=your-qdrant-api-key-here

# Redis Configuration (For BullMQ / Redis Cloud)
# You can supply a single connection URL (e.g. for Redis Cloud):
# REDIS_URL=redis://default:password@redis-cloud-host:port
# Or use individual configuration keys:
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=secret
# REDIS_USERNAME=default
# REDIS_TLS=false
